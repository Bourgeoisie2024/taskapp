name: CI/CD Pipeline # Name of the workflow
on:
  push: # Trigger the workflow on push events
    branches: 
      - main: # Specify the branch to trigger on
  pull_request: # Trigger the workflow on pull request events
    branches: 
      - main: # Specify the branch to trigger on
  schedule: # Trigger the workflow on a schedule
    - cron: '0 0 * * *' # Run daily at midnight
  workflow_dispatch: # Allow manual triggering of the workflow
  release: # Trigger the workflow on release events
    types: [created] # Specify the type of release event to trigger on

jobs: # Define the jobs to run in the workflow.
  build: # Name of the job
    runs-on: ubuntu-latest # Specify the runner environment
    steps: # Define the steps to execute in the job
      - name: Checkout code # Step to checkout the code
        uses: actions/checkout@v2 # # Use the checkout action

      - name: Set up Node.js # Step to set up Node.js environment
        uses: actions/setup-node@v2 # Use the setup-node action
        with:
          node-version: '14' # Specify the Node.js version

      - name: Install dependencies # Step to install dependencies
        run: npm install # Run npm install command

      - name: Run tests # Step to run tests
        run: npm test # Run apt test command

      - name: Build project # Step to build the project
        run: npm run build # Run npm run build command
      - name: Deploy # Step to deploy the project
        run: |
          echo "Deploying the project..." # Placeholder for deployment command
          echo "Deployment Complete!" # Placeholder for deployment completion message
          echo "Deployment successful!" # Placeholder for deployment success message
          cd build # Change to the build directory
          # Add deployment commands here, e.g., scp, rsync, or cloud deployment commands

